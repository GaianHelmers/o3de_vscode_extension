{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "npm",
      "script": "compile",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": "build",
      "presentation": { "reveal": "never" },
      "problemMatcher": {
        "owner": "esbuild",
        "source": "esbuild",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          { "regexp": "^✘ \\[ERROR\\] (.*)$", "message": 1 },
          { "regexp": "^\\s+(.*):(\\d+):(\\d+)$", "file": 1, "line": 2, "column": 3 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[esbuild\\] build started$",
          "endsPattern": "^\\[esbuild\\] build finished$"
        }
      }
    }
  ]
}
